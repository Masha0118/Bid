flowchart LR
    Participant["참가자"] --> Web["경매 참여와 결과 확인<br/>Bid On Web"]
    Web --> Control["경매 실행 제어"]
    Control --> Auction["입찰 판정과 종료 처리<br/>Auction Server"]
    Control --> Main["서비스 데이터 처리<br/>Main API"]

    Auction --> Redis[("입찰 판정과 런타임 상태<br/>Redis Lua")]
    Auction --> WS["참가자 상태 전달<br/>WebSocket"]
    WS --> Control
    Control --> Web
    Auction --> Kafka["입찰 이력 전달<br/>Kafka"]
    Rabbit["예약된 시작과 종료<br/>RabbitMQ"] --> Auction
    Main --> Rabbit
    Main --> DB[("영속 데이터<br/>PostgreSQL")]
    Auction --> DB

